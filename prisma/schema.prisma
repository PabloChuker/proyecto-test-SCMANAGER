generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Item {
  id            String          @id @default(uuid())
  reference     String          @unique
  name          String
  localizedName String?
  className     String?
  type          ItemType
  subType       String?
  size          Int?
  grade         String?
  manufacturer  String?
  mass          Float?
  hitPoints     Float?
  gameVersion   String
  rawData       Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  coolingStats  CoolingStats?
  equippedOn    Hardpoint[]     @relation("EquippedItem")
  hardpoints    Hardpoint[]
  miningStats   MiningStats?
  missileStats  MissileStats?
  powerStats    PowerStats?
  quantumStats  QuantumStats?
  shieldStats   ShieldStats?
  ship          Ship?
  shopInventory ShopInventory[]
  thrusterStats ThrusterStats?
  weaponStats   WeaponStats?

  @@index([type])
  @@index([type, size])
  @@index([manufacturer])
  @@index([gameVersion])
  @@map("items")
}

model WeaponStats {
  id            String  @id @default(uuid())
  itemId        String  @unique
  dps           Float?
  alphaDamage   Float?
  fireRate      Float?
  range         Float?
  speed         Float?
  ammoCount     Int?
  damageType    String?
  dmgPhysical   Float?
  dmgEnergy     Float?
  dmgDistortion Float?
  dmgThermal    Float?
  powerDraw     Float?
  thermalOutput Float?
  emSignature   Float?
  irSignature   Float?
  item          Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("weapon_stats")
}

model ShieldStats {
  id               String @id @default(uuid())
  itemId           String @unique
  maxHp            Float?
  regenRate        Float?
  downedDelay      Float?
  dmgAbsPhysical   Float?
  dmgAbsEnergy     Float?
  dmgAbsDistortion Float?
  powerDraw        Float?
  thermalOutput    Float?
  emSignature      Float?
  irSignature      Float?
  item             Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("shield_stats")
}

model PowerStats {
  id            String @id @default(uuid())
  itemId        String @unique
  powerOutput   Float?
  powerBase     Float?
  thermalOutput Float?
  emSignature   Float?
  irSignature   Float?
  item          Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("power_stats")
}

model CoolingStats {
  id              String @id @default(uuid())
  itemId          String @unique
  coolingRate     Float?
  suppressionHeat Float?
  suppressionIR   Float?
  powerDraw       Float?
  thermalOutput   Float?
  emSignature     Float?
  irSignature     Float?
  item            Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("cooling_stats")
}

model QuantumStats {
  id            String  @id @default(uuid())
  itemId        String  @unique
  maxSpeed      Float?
  maxRange      Float?
  fuelRate      Float?
  spoolUpTime   Float?
  cooldownTime  Float?
  stage1Accel   Float?
  stage2Accel   Float?
  quantumType   String?
  powerDraw     Float?
  thermalOutput Float?
  emSignature   Float?
  irSignature   Float?
  item          Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("quantum_stats")
}

model MiningStats {
  id            String @id @default(uuid())
  itemId        String @unique
  miningPower   Float?
  resistance    Float?
  instability   Float?
  optimalRange  Float?
  maxRange      Float?
  throttleRate  Float?
  powerDraw     Float?
  thermalOutput Float?
  item          Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("mining_stats")
}

model MissileStats {
  id            String  @id @default(uuid())
  itemId        String  @unique
  damage        Float?
  lockTime      Float?
  lockRange     Float?
  trackingAngle Float?
  speed         Float?
  fuelTime      Float?
  lockingType   String?
  item          Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("missile_stats")
}

model ThrusterStats {
  id             String  @id @default(uuid())
  itemId         String  @unique
  thrustCapacity Float?
  maxThrust      Float?
  fuelBurnRate   Float?
  thrustType     String?
  powerDraw      Float?
  thermalOutput  Float?
  emSignature    Float?
  item           Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("thruster_stats")
}

model Ship {
  id               String           @id @default(uuid())
  itemId           String           @unique
  maxCrew          Int?
  cargo            Float?
  scmSpeed         Float?
  afterburnerSpeed Float?
  pitchRate        Float?
  yawRate          Float?
  rollRate         Float?
  maxAccelMain     Float?
  maxAccelRetro    Float?
  hydrogenFuelCap  Float?
  quantumFuelCap   Float?
  lengthMeters     Float?
  beamMeters       Float?
  heightMeters     Float?
  role             String?
  focus            String?
  career           String?
  isSpaceship      Boolean          @default(true)
  isGravlev        Boolean          @default(false)
  baseEmSignature  Float?
  baseIrSignature  Float?
  baseCsSignature  Float?
  item             Item             @relation(fields: [itemId], references: [id], onDelete: Cascade)
  flightStats      ShipFlightStats?
  resistances      ShipResistances?
  fuel             ShipFuel?
  insurance        ShipInsurance?

  @@map("ships")
}

// ── Satellite: Flight & Performance (SPViewer Level) ──
model ShipFlightStats {
  id                    String @id @default(uuid())
  shipId                String @unique
  // Speeds
  scmSpeed              Float?
  maxSpeed              Float?
  boostSpeedForward     Float?
  boostSpeedBackward    Float?
  // Angular rates (deg/s)
  pitch                 Float?
  yaw                   Float?
  roll                  Float?
  pitchBoosted          Float?
  yawBoosted            Float?
  rollBoosted           Float?
  // Acceleration (m/s²)
  accelForward          Float?
  accelBackward         Float?
  accelUp               Float?
  accelDown             Float?
  accelStrafe           Float?
  // Acceleration in G
  accelForwardG         Float?
  accelBackwardG        Float?
  accelUpG              Float?
  accelDownG            Float?
  accelStrafeG          Float?
  // Boost multipliers
  boostMultForward      Float?
  boostMultBackward     Float?
  boostMultUp           Float?
  boostMultStrafe       Float?
  // Boost capacitor
  boostCapacitorMax     Float?
  boostRegenPerSec      Float?
  boostRegenTime        Float?
  // Timing (seconds)
  zeroToScm             Float?
  zeroToMax             Float?
  scmToZero             Float?
  // Mass
  massEmpty             Float?
  massLoadout           Float?
  massTotal             Float?
  ship                  Ship   @relation(fields: [shipId], references: [id], onDelete: Cascade)

  @@map("ship_flight_stats")
}

// ── Satellite: Armor, Resistances & Signatures ──
model ShipResistances {
  id                    String @id @default(uuid())
  shipId                String @unique
  // Hull armor HP
  armorHp               Float?
  // Damage multipliers (lower = more resistant)
  dmgMultPhysical       Float?
  dmgMultEnergy         Float?
  dmgMultDistortion     Float?
  dmgMultThermal        Float?
  dmgMultBiochemical    Float?
  dmgMultStun           Float?
  // Signal multipliers
  sigMultCrossSection   Float?
  sigMultInfrared       Float?
  sigMultElectromagnetic Float?
  // Penetration resistance
  penResistBase         Float?
  penResistPhysical     Float?
  penResistEnergy       Float?
  penResistDistortion   Float?
  // Base signatures (ship-level)
  baseEmSignature       Float?
  baseIrSignature       Float?
  baseCsSignature       Float?
  // Cross-section axes
  crossSectionX         Float?
  crossSectionY         Float?
  crossSectionZ         Float?
  // Emission totals
  emTotalShields        Float?
  emTotalQuantum        Float?
  irTotalShields        Float?
  irTotalQuantum        Float?
  ship                  Ship   @relation(fields: [shipId], references: [id], onDelete: Cascade)

  @@map("ship_resistances")
}

// ── Satellite: Fuel & Propulsion Economy ──
model ShipFuel {
  id                    String @id @default(uuid())
  shipId                String @unique
  // Hydrogen fuel
  hydrogenCapacity      Float?
  fuelIntakeRate        Float?
  fuelUsageMain         Float?
  fuelUsageRetro        Float?
  fuelUsageManeuvering  Float?
  maneuveringTimeTillEmpty Float?
  intakeToMainRatio     Float?
  // Quantum fuel
  quantumCapacity       Float?
  quantumRange          Float?
  quantumSpeed          Float?
  quantumSpoolTime      Float?
  quantumTravelTimePO   Float?
  quantumFuelUsagePO    Float?
  // Thrust capacities
  thrustMain            Float?
  thrustRetro           Float?
  thrustManeuvering     Float?
  // Power budget (segments)
  powerGeneration       Float?
  powerUsedShields      Float?
  powerUsedQuantum      Float?
  // Cooling budget (segments)
  coolingGeneration     Float?
  coolingUsedShields    Float?
  coolingUsedQuantum    Float?
  // Shield totals
  shieldHpTotal         Float?
  shieldRegenTotal      Float?
  ship                  Ship   @relation(fields: [shipId], references: [id], onDelete: Cascade)

  @@map("ship_fuel")
}

// ── Satellite: Insurance ──
model ShipInsurance {
  id                    String @id @default(uuid())
  shipId                String @unique
  expeditedCost         Float?
  expeditedClaimTime    Float?
  standardClaimTime     Float?
  ship                  Ship   @relation(fields: [shipId], references: [id], onDelete: Cascade)

  @@map("ship_insurance")
}

// ── Localization (Multi-language) ──
model Translation {
  id        String @id @default(uuid())
  key       String
  locale    String
  value     String
  category  String?

  @@unique([key, locale])
  @@index([key])
  @@index([locale])
  @@map("translations")
}

model Hardpoint {
  id             String            @id @default(uuid())
  parentItemId   String
  hardpointName  String
  category       HardpointCategory
  minSize        Int               @default(0)
  maxSize        Int               @default(0)
  isFixed        Boolean           @default(false)
  isManned       Boolean           @default(false)
  isInternal     Boolean           @default(false)
  equippedItemId String?
  equippedItem   Item?             @relation("EquippedItem", fields: [equippedItemId], references: [id])
  parentItem     Item              @relation(fields: [parentItemId], references: [id], onDelete: Cascade)

  @@unique([parentItemId, hardpointName])
  @@index([parentItemId])
  @@index([category])
  @@map("hardpoints")
}

model Location {
  id         String  @id @default(uuid())
  name       String
  type       String
  parentName String?
  system     String?
  shops      Shop[]

  @@unique([name, parentName])
  @@map("locations")
}

model Shop {
  id         String          @id @default(uuid())
  name       String
  locationId String
  shopType   String?
  inventory  ShopInventory[]
  location   Location        @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([name, locationId])
  @@index([locationId])
  @@map("shops")
}

model ShopInventory {
  id          String  @id @default(uuid())
  shopId      String
  itemId      String
  priceBuy    Float?
  priceSell   Float?
  isAvailable Boolean @default(true)
  stock       Int?
  item        Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  shop        Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, itemId])
  @@index([itemId])
  @@map("shop_inventory")
}

model GameVersion {
  id          String   @id @default(uuid())
  version     String   @unique
  source      String
  itemCount   Int      @default(0)
  processedAt DateTime @default(now())
  notes       String?

  @@map("game_versions")
}

enum ItemType {
  SHIP
  VEHICLE
  WEAPON
  MISSILE
  TORPEDO
  BOMB
  SHIELD
  ARMOR
  COUNTERMEASURE
  POWER_PLANT
  COOLER
  QUANTUM_DRIVE
  RADAR
  AVIONICS
  THRUSTER
  FUEL_TANK
  FUEL_INTAKE
  MINING_LASER
  SALVAGE_HEAD
  TRACTOR_BEAM
  EMP
  QED
  TURRET
  COMMODITY
  MINERAL
  GAS
  RAW_MATERIAL
  REFINED_MATERIAL
  COMPONENT_PART
  PAINT
  PERSONAL_WEAPON
  GADGET
  OTHER
}

enum HardpointCategory {
  WEAPON
  MISSILE_RACK
  TURRET
  SHIELD
  POWER_PLANT
  COOLER
  QUANTUM_DRIVE
  THRUSTER_MAIN
  THRUSTER_MANEUVERING
  RADAR
  AVIONICS
  ARMOR
  FUEL_TANK
  FUEL_INTAKE
  COUNTERMEASURE
  MINING
  SALVAGE
  TRACTOR_BEAM
  UTILITY
  OTHER
}

