// =============================================================================
// AL FILO — Star Citizen Platform
// Prisma Schema v1.0 — Fase 1: Naves, Hardpoints y Componentes
// =============================================================================
// Filosofía: Todo en Star Citizen es un "Item". Una nave es un item, un laser
// repeater es un item, un escudo es un item. La tabla central evita duplicación.
// Los UUIDs que usamos son los mismos que CIG asigna internamente (reference).
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// TABLA CENTRAL: Item
// Cada entidad del juego es un Item. El campo `type` discrimina qué es.
// `rawData` guarda el JSON original de scunpacked para debug/auditoría.
// =============================================================================
model Item {
  id            String   @id @default(uuid()) // PK interna
  reference     String   @unique               // UUID de CIG (ej: "abc-123-def")
  name          String                          // Nombre legible (ej: "Gladius")
  localizedName String?                         // Nombre localizado si existe
  className     String?                         // Nombre de clase interno de CIG
  type          ItemType                        // Enum: SHIP, WEAPON, SHIELD, etc.
  subType       String?                         // Sub-clasificación libre
  size          Int?                            // Tamaño del item (S1-S12 para armas, etc.)
  grade         String?                         // Grado (A, B, C, D) si aplica
  manufacturer  String?                         // Fabricante (Aegis, RSI, etc.)
  mass          Float?                          // Masa en kg
  hitPoints     Float?                          // Puntos de vida del componente
  gameVersion   String                          // Versión del juego (ej: "4.0.1")
  rawData       Json?                           // JSON crudo de scunpacked para referencia
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // -- Relaciones --
  ship           Ship?                          // Si type=SHIP, datos extendidos
  componentStats ComponentStats?                // Stats específicas del componente
  hardpoints     Hardpoint[]                    // Hardpoints que TIENE este item (si es nave)
  equippedOn     Hardpoint[]    @relation("EquippedItem") // Hardpoints donde ESTÁ equipado

  @@index([type])
  @@index([manufacturer])
  @@index([gameVersion])
  @@map("items")
}

// =============================================================================
// ENUM: Tipos de Item
// Se expande en fases futuras con MINERAL, COMMODITY, RECIPE, etc.
// =============================================================================
enum ItemType {
  SHIP
  VEHICLE
  WEAPON
  MISSILE
  SHIELD
  POWER_PLANT
  COOLER
  QUANTUM_DRIVE
  THRUSTER
  ARMOR
  RADAR
  AVIONICS
  MINING_LASER
  TURRET
  COUNTERMEASURE
  FUEL_TANK
  FUEL_INTAKE
  OTHER
}

// =============================================================================
// SHIP: Datos extendidos para naves/vehículos
// Relación 1:1 con Item. Solo existe si item.type == SHIP o VEHICLE
// =============================================================================
model Ship {
  id               String  @id @default(uuid())
  itemId           String  @unique
  item             Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)

  // --- Estadísticas de vuelo ---
  maxCrew          Int?
  cargo            Float?    // SCU de carga
  maxSpeed         Float?    // m/s velocidad máxima SCM
  afterburnerSpeed Float?    // m/s con afterburner
  pitchRate        Float?    // Grados/s
  yawRate          Float?    // Grados/s
  rollRate         Float?    // Grados/s

  // --- Capacidades ---
  hydrogenFuelCap  Float?    // Capacidad de hidrógeno
  quantumFuelCap   Float?    // Capacidad de quantum fuel
  isSpaceship      Boolean   @default(true)
  isGravlev        Boolean   @default(false)

  // --- Dimensiones ---
  lengthMeters     Float?
  beamMeters       Float?
  heightMeters     Float?

  // --- Clasificación ---
  role             String?   // Fighter, Mining, Cargo, etc.
  focus            String?   // Light Fighter, Medium Freight, etc.
  career           String?   // Combat, Industry, Transport, etc.

  @@map("ships")
}

// =============================================================================
// HARDPOINT: Punto de montaje en una nave
// Cada nave tiene N hardpoints. Cada hardpoint acepta items de cierto tipo/tamaño.
// =============================================================================
model Hardpoint {
  id              String        @id @default(uuid())
  parentItemId    String                        // La nave/vehículo dueña
  parentItem      Item          @relation(fields: [parentItemId], references: [id], onDelete: Cascade)

  hardpointName   String                        // Nombre interno (ej: "hardpoint_weapon_gun_class2_right")
  category        HardpointCategory             // WEAPON, SHIELD, POWER_PLANT, etc.
  minSize         Int           @default(0)     // Tamaño mínimo que acepta
  maxSize         Int           @default(0)     // Tamaño máximo que acepta
  isFixed         Boolean       @default(false) // ¿Es fijo o gimbal?
  isManned        Boolean       @default(false) // ¿Requiere tripulante?
  isInternal      Boolean       @default(false) // ¿Es componente interno?

  // --- Item actualmente equipado (default loadout) ---
  equippedItemId  String?
  equippedItem    Item?         @relation("EquippedItem", fields: [equippedItemId], references: [id], onDelete: SetNull)

  @@index([parentItemId])
  @@index([category])
  @@map("hardpoints")
}

enum HardpointCategory {
  WEAPON
  MISSILE_RACK
  TURRET
  SHIELD
  POWER_PLANT
  COOLER
  QUANTUM_DRIVE
  THRUSTER_MAIN
  THRUSTER_MANEUVERING
  RADAR
  AVIONICS
  ARMOR
  FUEL_TANK
  FUEL_INTAKE
  COUNTERMEASURE
  MINING
  UTILITY
  OTHER
}

// =============================================================================
// COMPONENT STATS: Estadísticas detalladas de cada componente
// Relación 1:1 con Item. Almacena métricas de rendimiento.
// Usamos campos nullable porque cada tipo de componente tiene stats distintas.
// =============================================================================
model ComponentStats {
  id              String  @id @default(uuid())
  itemId          String  @unique
  item            Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)

  // --- Armas ---
  dps             Float?    // Damage per second total
  alphaDamage     Float?    // Daño por disparo
  fireRate        Float?    // Disparos por minuto
  range           Float?    // Alcance efectivo en metros
  speed           Float?    // Velocidad del proyectil m/s
  ammoCount       Int?      // Munición total (-1 = energy)
  damageType      String?   // Physical, Energy, Distortion, etc.

  // --- Escudos ---
  shieldHp        Float?    // HP del escudo
  shieldRegen     Float?    // Regeneración por segundo
  shieldDownDelay Float?    // Segundos para empezar a regenerar tras caer

  // --- Power Plant ---
  powerOutput     Float?    // Generación de energía

  // --- Cooler ---
  coolingRate     Float?    // Tasa de enfriamiento

  // --- Quantum Drive ---
  quantumSpeed    Float?    // Velocidad quantum en m/s
  quantumRange    Float?    // Rango máximo
  quantumCooldown Float?    // Cooldown entre saltos
  quantumSpoolUp  Float?    // Tiempo de spool up

  // --- Consumo (universal) ---
  powerDraw       Float?    // Consumo de energía
  thermalOutput   Float?    // Generación de calor
  emSignature     Float?    // Firma electromagnética
  irSignature     Float?    // Firma infrarroja

  @@map("component_stats")
}

// =============================================================================
// GAME VERSION: Registro de versiones procesadas
// Para tracking de qué parches hemos ingestado y cuándo.
// =============================================================================
model GameVersion {
  id          String   @id @default(uuid())
  version     String   @unique              // "4.0.1", "4.0.2", etc.
  source      String                        // "scunpacked", "manual", "p4k"
  itemCount   Int      @default(0)          // Cantidad de items procesados
  processedAt DateTime @default(now())
  notes       String?

  @@map("game_versions")
}
