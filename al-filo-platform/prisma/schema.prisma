generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Item {
  id            String          @id @default(uuid())
  reference     String          @unique
  name          String
  localizedName String?
  className     String?
  type          ItemType
  subType       String?
  size          Int?
  grade         String?
  manufacturer  String?
  mass          Float?
  hitPoints     Float?
  gameVersion   String
  rawData       Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  coolingStats  CoolingStats?
  equippedOn    Hardpoint[]     @relation("EquippedItem")
  hardpoints    Hardpoint[]
  miningStats   MiningStats?
  missileStats  MissileStats?
  powerStats    PowerStats?
  quantumStats  QuantumStats?
  shieldStats   ShieldStats?
  ship          Ship?
  shopInventory ShopInventory[]
  thrusterStats ThrusterStats?
  weaponStats   WeaponStats?

  @@index([type])
  @@index([type, size])
  @@index([manufacturer])
  @@index([gameVersion])
  @@map("items")
}

model WeaponStats {
  id            String  @id @default(uuid())
  itemId        String  @unique
  dps           Float?
  alphaDamage   Float?
  fireRate      Float?
  range         Float?
  speed         Float?
  ammoCount     Int?
  damageType    String?
  dmgPhysical   Float?
  dmgEnergy     Float?
  dmgDistortion Float?
  dmgThermal    Float?
  powerDraw     Float?
  thermalOutput Float?
  emSignature   Float?
  irSignature   Float?
  item          Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("weapon_stats")
}

model ShieldStats {
  id               String @id @default(uuid())
  itemId           String @unique
  maxHp            Float?
  regenRate        Float?
  downedDelay      Float?
  dmgAbsPhysical   Float?
  dmgAbsEnergy     Float?
  dmgAbsDistortion Float?
  powerDraw        Float?
  thermalOutput    Float?
  emSignature      Float?
  irSignature      Float?
  item             Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("shield_stats")
}

model PowerStats {
  id            String @id @default(uuid())
  itemId        String @unique
  powerOutput   Float?
  powerBase     Float?
  thermalOutput Float?
  emSignature   Float?
  irSignature   Float?
  item          Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("power_stats")
}

model CoolingStats {
  id              String @id @default(uuid())
  itemId          String @unique
  coolingRate     Float?
  suppressionHeat Float?
  suppressionIR   Float?
  powerDraw       Float?
  thermalOutput   Float?
  emSignature     Float?
  irSignature     Float?
  item            Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("cooling_stats")
}

model QuantumStats {
  id            String  @id @default(uuid())
  itemId        String  @unique
  maxSpeed      Float?
  maxRange      Float?
  fuelRate      Float?
  spoolUpTime   Float?
  cooldownTime  Float?
  stage1Accel   Float?
  stage2Accel   Float?
  quantumType   String?
  powerDraw     Float?
  thermalOutput Float?
  emSignature   Float?
  irSignature   Float?
  item          Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("quantum_stats")
}

model MiningStats {
  id            String @id @default(uuid())
  itemId        String @unique
  miningPower   Float?
  resistance    Float?
  instability   Float?
  optimalRange  Float?
  maxRange      Float?
  throttleRate  Float?
  powerDraw     Float?
  thermalOutput Float?
  item          Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("mining_stats")
}

model MissileStats {
  id            String  @id @default(uuid())
  itemId        String  @unique
  damage        Float?
  lockTime      Float?
  lockRange     Float?
  trackingAngle Float?
  speed         Float?
  fuelTime      Float?
  lockingType   String?
  item          Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("missile_stats")
}

model ThrusterStats {
  id             String  @id @default(uuid())
  itemId         String  @unique
  thrustCapacity Float?
  maxThrust      Float?
  fuelBurnRate   Float?
  thrustType     String?
  powerDraw      Float?
  thermalOutput  Float?
  emSignature    Float?
  item           Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("thruster_stats")
}

model Ship {
  id               String  @id @default(uuid())
  itemId           String  @unique
  maxCrew          Int?
  cargo            Float?
  scmSpeed         Float?
  afterburnerSpeed Float?
  pitchRate        Float?
  yawRate          Float?
  rollRate         Float?
  maxAccelMain     Float?
  maxAccelRetro    Float?
  hydrogenFuelCap  Float?
  quantumFuelCap   Float?
  lengthMeters     Float?
  beamMeters       Float?
  heightMeters     Float?
  role             String?
  focus            String?
  career           String?
  isSpaceship      Boolean @default(true)
  isGravlev        Boolean @default(false)
  baseEmSignature  Float?
  baseIrSignature  Float?
  baseCsSignature  Float?
  item             Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@map("ships")
}

model Hardpoint {
  id             String            @id @default(uuid())
  parentItemId   String
  hardpointName  String
  category       HardpointCategory
  minSize        Int               @default(0)
  maxSize        Int               @default(0)
  isFixed        Boolean           @default(false)
  isManned       Boolean           @default(false)
  isInternal     Boolean           @default(false)
  equippedItemId String?
  equippedItem   Item?             @relation("EquippedItem", fields: [equippedItemId], references: [id])
  parentItem     Item              @relation(fields: [parentItemId], references: [id], onDelete: Cascade)

  @@unique([parentItemId, hardpointName])
  @@index([parentItemId])
  @@index([category])
  @@map("hardpoints")
}

model Location {
  id         String  @id @default(uuid())
  name       String
  type       String
  parentName String?
  system     String?
  shops      Shop[]

  @@unique([name, parentName])
  @@map("locations")
}

model Shop {
  id         String          @id @default(uuid())
  name       String
  locationId String
  shopType   String?
  inventory  ShopInventory[]
  location   Location        @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([name, locationId])
  @@index([locationId])
  @@map("shops")
}

model ShopInventory {
  id          String  @id @default(uuid())
  shopId      String
  itemId      String
  priceBuy    Float?
  priceSell   Float?
  isAvailable Boolean @default(true)
  stock       Int?
  item        Item    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  shop        Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, itemId])
  @@index([itemId])
  @@map("shop_inventory")
}

model GameVersion {
  id          String   @id @default(uuid())
  version     String   @unique
  source      String
  itemCount   Int      @default(0)
  processedAt DateTime @default(now())
  notes       String?

  @@map("game_versions")
}

enum ItemType {
  SHIP
  VEHICLE
  WEAPON
  MISSILE
  TORPEDO
  BOMB
  SHIELD
  ARMOR
  COUNTERMEASURE
  POWER_PLANT
  COOLER
  QUANTUM_DRIVE
  RADAR
  AVIONICS
  THRUSTER
  FUEL_TANK
  FUEL_INTAKE
  MINING_LASER
  SALVAGE_HEAD
  TRACTOR_BEAM
  EMP
  QED
  TURRET
  COMMODITY
  MINERAL
  GAS
  RAW_MATERIAL
  REFINED_MATERIAL
  COMPONENT_PART
  PAINT
  PERSONAL_WEAPON
  GADGET
  OTHER
}

enum HardpointCategory {
  WEAPON
  MISSILE_RACK
  TURRET
  SHIELD
  POWER_PLANT
  COOLER
  QUANTUM_DRIVE
  THRUSTER_MAIN
  THRUSTER_MANEUVERING
  RADAR
  AVIONICS
  ARMOR
  FUEL_TANK
  FUEL_INTAKE
  COUNTERMEASURE
  MINING
  SALVAGE
  TRACTOR_BEAM
  UTILITY
  OTHER
}

